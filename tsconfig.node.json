{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["server", "src/types", "vite.config.ts", "postcss.config.js", "tailwind.config.js"]
}
